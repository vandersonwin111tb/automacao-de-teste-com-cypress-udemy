{
  "env": {
    "browser": true,
    "es2021": true,
    "mocha": true,
    "cypress/globals": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:cypress/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "cypress"
  ],
  "rules": {
    "indent": ["error", 4],
    "no-console": "warn"
  }
}